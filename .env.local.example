# Catalst Market — local environment template.
# Copy this file to .env.local and fill in real values. .env.local is
# gitignored; this template is committed so the required keys are
# discoverable.
#
# Phase 7c — JSON-first live ingest. No database keys are required;
# the live store is a single JSON file at content/stories.live.json.

# Required — shared secret guarding /api/ingest. Make this a random
# string the orchestrator (cron, manual curl) will pass via
# ?secret=… query param. Generate one with `openssl rand -hex 16`.
INGEST_SECRET=

# Optional — Product Hunt developer token. The producthunt adapter
# returns [] gracefully when this is missing, so the rest of the
# pipeline still runs. Get a token at
# https://api.producthunt.com/v2/oauth/applications and click
# "Create token (for testing)".
PRODUCTHUNT_TOKEN=

# Optional — public app URL used by client-side reachability checks.
# Defaults to http://localhost:3000 in dev when unset.
NEXT_PUBLIC_APP_URL=http://localhost:3000
